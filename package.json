{
  "name": "scipen-studio",
  "version": "0.3.2",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "description": "SciPen Studio - AI-Powered LaTeX/Typst IDE for Scientific Research",
  "author": {
    "name": "SciPen Team",
    "email": "democat.iu@qq.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/scipenai/scipen-studio.git"
  },
  "bugs": {
    "url": "https://github.com/scipenai/scipen-studio/issues"
  },
  "homepage": "https://github.com/scipenai/scipen-studio#readme",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run build:workers && electron-vite dev",
    "build": "npm run prebuild && npm run typecheck:all && electron-vite build && npm run build:workers",
    "build:win": "npm run prebuild && npm run typecheck:all && electron-vite build && npm run build:workers && electron-builder --win --x64",
    "build:mac": "npm run prebuild && npm run typecheck:all && electron-vite build && npm run build:workers && electron-builder --mac",
    "build:linux": "npm run prebuild && npm run typecheck:all && electron-vite build && npm run build:workers && electron-builder --linux",
    "build:workers": "node scripts/build-workers.js",
    "build:icon": "node scripts/build-icon.mjs",
    "start": "npm run dev",
    "lint": "oxlint --fix && npm run typecheck:all",
    "lint:check": "oxlint",
    "lint:no-cjk": "node scripts/check-no-cjk.js",
    "format": "biome format --write && biome lint --write",
    "format:check": "biome format && biome lint",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --project tsconfig.node.json --noEmit",
    "typecheck:all": "npm run typecheck && npm run typecheck:node",
    "ci:local": "npm run lint:check && npm run format:check && npm run typecheck:all && npm run test:run && npm run build:workers && npx electron-vite build",
    "ci:quick": "npm run lint:check && npm run typecheck:all",
    "postinstall": "patch-package && electron-builder install-app-deps",
    "rebuild:native": "electron-rebuild -f -w @parcel/watcher,selection-hook",
    "download:texlab": "node scripts/download-texlab.js",
    "download:tinymist": "node scripts/download-tinymist.js",
    "download:marksman": "node scripts/download-marksman.js",
    "download:lsp": "npm run download:texlab && npm run download:tinymist && npm run download:marksman",
    "download:busytex": "node scripts/download-busytex-wasm.js",
    "download:busytex:minimal": "node scripts/download-busytex-wasm.js --minimal",
    "download:typst-wasm": "node scripts/download-typst-wasm.js",
    "download:typst-wasm:cjk": "node scripts/download-typst-wasm.js --cjk",
    "download:typst-wasm:no-fonts": "node scripts/download-typst-wasm.js --no-fonts",
    "copy:public-assets": "node scripts/copy-public-assets.js",
    "build:snaca": "node scripts/build-snaca.js",
    "deploy:snaca": "node scripts/build-snaca.js --install",
    "copy:skills": "node scripts/copy-skills.js",
    "prebuild": "npm run download:lsp && npm run download:busytex && npm run download:typst-wasm:cjk && npm run copy:public-assets && npm run build:snaca && npm run copy:skills",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "npm install && npm run download:lsp"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.1",
    "@ai-sdk/openai": "^3.0.1",
    "@gsap/react": "~2.1.2",
    "@monaco-editor/react": "^4.7.0",
    "@parcel/watcher": "^2.5.4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/fs-extra": "^11.0.4",
    "ai": "^6.0.3",
    "autoprefixer": "^10.4.22",
    "clsx": "^2.1.1",
    "diff-match-patch": "^1.0.5",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "~2.0.1",
    "framer-motion": "^12.23.24",
    "fs-extra": "^11.3.3",
    "github-slugger": "^2.0.0",
    "gsap": "~3.15.0",
    "katex": "^0.16.25",
    "lru-cache": "^11.0.2",
    "lucide-react": "^0.555.0",
    "mime-types": "^3.0.2",
    "minimatch": "^10.0.1",
    "monaco-editor": "^0.55.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "~5.4.394",
    "postcss": "^8.5.6",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "react-virtuoso": "^4.12.3",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "selection-hook": "^1.0.12",
    "socket.io-client": "github:overleaf/socket.io-client#0.9.17-overleaf-5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.17",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "uuid": "^11.1.1",
    "ws": "^8.18.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@electron/rebuild": "~4.0.4",
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/diff-match-patch": "^1.0.36",
    "@types/glob": "^8.1.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "~24.9.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "@vitest/coverage-v8": "^4.0.15",
    "electron": "~42.2.0",
    "electron-builder": "~26.8.1",
    "electron-vite": "~3.1.0",
    "esbuild": "^0.24.0",
    "happy-dom": "^20.0.11",
    "oxlint": "^1.0.0",
    "patch-package": "^8.0.0",
    "playwright": "^1.48.0",
    "sharp": "^0.34.5",
    "tailwindcss-animate": "^1.0.7",
    "to-ico": "^1.1.5",
    "typescript": "^5.8.3",
    "vite": "^5.1.6",
    "vitest": "^4.0.15"
  }
}
