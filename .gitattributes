* text=auto eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.sqlite binary
*.wasm binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.zip binary
*.tar binary
*.gz binary

# Windows-only scripts keep CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
